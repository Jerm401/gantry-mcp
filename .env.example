# Default credentials used when --user/--pass flags are omitted.
# Copy this file to ".env" and fill in real values.
GANTRY_ADMIN_USER=your_joomla_admin_username
GANTRY_ADMIN_PASS=your_joomla_admin_password

# Optional: per-site overrides. The host is uppercased with dots/dashes -> underscores.
# Example for "https://example.com" -> EXAMPLE_COM_USER / EXAMPLE_COM_PASS
# EXAMPLE_COM_USER=admin
# EXAMPLE_COM_PASS=hunter2

# Optional: default theme name (defaults to "studius").
GANTRY_THEME=studius

# Optional: where Puppeteer stores its persistent profile (cookies, etc.)
# Useful so you don't re-login every run.
GANTRY_USER_DATA_DIR=./.puppeteer-profile

# Optional: extra slow-mo (ms) when running visible — helps you watch.
GANTRY_SLOWMO=0
